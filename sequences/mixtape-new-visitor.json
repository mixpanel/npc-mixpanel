{
	"new-visitor": {
		"description": "New Visitor: brief visit, play 1 track, signup, partial onboarding (abandon at artist step)",
		"temperature": 7,
		"chaos-range": [7, 12],
		"circuitBreaker": { "maxFailures": 5, "resetOnSuccess": true, "mode": "skip" },
		"actions": [
			{ "action": "click", "selector": "#landingCta" },
			{ "action": "click", "selector": ".genre-pill:nth-child(3)" },
			{ "action": "click", "selector": ".track-card:nth-child(1)" },
			{ "action": "click", "selector": "#btnSignup" },
			{ "action": "type", "selector": "#signupName", "text": "{{displayName}}" },
			{ "action": "type", "selector": "#signupEmail", "text": "{{email}}" },
			{ "action": "click", "selector": "#signupForm button[type=\"submit\"]" },
			{ "action": "click", "selector": ".genre-select-card:nth-child(2)" },
			{ "action": "click", "selector": "#onboarding1Continue" }
		]
	}
}
