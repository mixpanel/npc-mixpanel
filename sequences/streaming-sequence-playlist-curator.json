{
	"playlist-curator": {
		"description": "Power-user flag-driven flow for me-tube-ai-playlist-maker: lands, opens floating Playlist Builder (bottom-left, Sparkles+ListVideo icons), types a prompt, generates an AI playlist, scrolls results, saves and copies. Then watches a video from the main grid. Story: AI playlist feature engagement; tests me-tube-ai-playlist-maker variant impact (Control vs A vs B). Dashboard: funnel Opened Playlist Builder -> Generated Playlist -> Saved Playlist, breakdown by AI Playlist Maker variant; cohort = users with Saved Playlist event.",
		"persona": "methodical",
		"temperature": 10,
		"chaos-range": [10, 10],
		"circuitBreaker": { "maxFailures": 5, "resetOnSuccess": true, "mode": "skip" },
		"actions": [
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "wait", "tier": "micro" },
			{ "action": "scroll", "direction": "up", "amount": "half" },
			{ "action": "hover", "selector": "button:has(svg.lucide-list-video)" },
			{ "action": "click", "selector": "button:has(svg.lucide-list-video)", "textFallback": "Playlist Builder" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "input[placeholder*='workout']" },
			{ "action": "type", "selector": "input[placeholder*='workout']", "text": "morning workout videos" },
			{ "action": "wait", "tier": "micro" },
			{ "action": "click", "selector": "button:has(svg.lucide-sparkles)", "textFallback": "Generate" },
			{ "action": "wait", "ms": 5000 },
			{ "action": "scroll", "selector": ".bg-white.rounded-lg", "amount": "half" },
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "wait", "tier": "micro" },
			{ "action": "scroll", "direction": "down", "amount": "half" },
			{ "action": "hover", "selector": "button:has(svg.lucide-save)" },
			{ "action": "click", "selector": "button:has(svg.lucide-save)", "textFallback": "Save Playlist" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "button:has(svg.lucide-copy)", "textFallback": "Copy to Clipboard" },
			{ "action": "wait", "tier": "micro" },
			{ "action": "click", "selector": "button:has(svg.lucide-x)", "textFallback": "Close" },
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "direction": "up", "amount": "page" },
			{ "action": "wait", "tier": "micro" },
			{
				"action": "click",
				"selector": ".bg-white.rounded-lg:nth-child(2)",
				"expectsNavigation": true,
				"navigationTimeout": 8000
			},
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "click", "selector": "button:has(svg.lucide-thumbs-up)", "textFallback": "Like" },
			{ "action": "click", "selector": "button:has(svg.lucide-thumbs-up)", "textFallback": "Like" },
			{ "action": "click", "selector": "button:has(svg.lucide-thumbs-up)", "textFallback": "Like" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "button:has(svg.lucide-user-plus)", "textFallback": "Subscribe" },
			{ "action": "click", "selector": "button:has(svg.lucide-user-plus)", "textFallback": "Subscribe" },
			{ "action": "click", "selector": "button:has(svg.lucide-user-plus)", "textFallback": "Subscribe" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "wait", "tier": "read" },
			{ "action": "navigate" }
		]
	}
}
