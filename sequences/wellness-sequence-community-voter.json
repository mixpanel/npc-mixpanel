{
	"community-voter": {
		"description": "First-time community voter: lands on ourHeart, navigates to /wellness/vote/, methodically reads each case, picks an orange-bordered diagnosis vote, clicks Next Case, repeats across 6 cases, eventually hits the All Done state. Story: voting funnel completion across the case set. Dashboard: Vote Cast event count >= 3, Voting Completed cohort.",
		"persona": "methodical",
		"temperature": 9,
		"chaos-range": [8, 10],
		"circuitBreaker": { "maxFailures": 5, "resetOnSuccess": true, "mode": "skip" },
