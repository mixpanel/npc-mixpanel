			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{
				"action": "click",
				"selector": "a[href*=\"/wellness/vote\"]",
				"textFallback": "Vote",
				"expectsNavigation": true,
				"navigationTimeout": 8000
			},
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "wait", "tier": "think" },
			{ "action": "click", "selector": "button.border-orange-200" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#nonexistent-next-case", "textFallback": "Next Case" },
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "wait", "tier": "think" },
			{ "action": "click", "selector": "button.border-orange-200" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#nonexistent-next-case", "textFallback": "Next Case" },
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "wait", "tier": "think" },
			{ "action": "click", "selector": "button.border-orange-200" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#nonexistent-next-case", "textFallback": "Next Case" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "button.border-orange-200" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#nonexistent-next-case", "textFallback": "Next Case" },
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" }
		]
	}
