{
	"casual-browser": {
		"description": "Casual Browser: browse genres, play a few tracks, hit paywall, dismiss, leave",
		"temperature": 8,
		"chaos-range": [8, 12],
		"circuitBreaker": { "maxFailures": 5, "resetOnSuccess": true, "mode": "skip" },
		"actions": [
			{ "action": "click", "selector": "#landingCta" },
			{ "action": "click", "selector": ".genre-pill:nth-child(2)" },
			{ "action": "click", "selector": ".track-card:nth-child(1)" },
			{ "action": "click", "selector": "#genreBackBtn" },
			{ "action": "click", "selector": ".genre-pill:nth-child(4)" },
			{ "action": "click", "selector": ".track-card:nth-child(1)" },
			{ "action": "click", "selector": ".track-card:nth-child(2)" },
			{ "action": "click", "selector": "#paywallClose" }
		]
	}
}
