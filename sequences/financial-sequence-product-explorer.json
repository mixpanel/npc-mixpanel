{
	"product-explorer": {
		"description": "Methodical user who explores the product demo (investments/savings/expenses tabs, rebalance, generate report) deeply before committing to signup. Story: high-engagement before conversion. Dashboard: Product Tab Switched, Investment Adjusted, Report Generated → Account Created funnel.",
		"persona": "methodical",
		"temperature": 10,
		"chaos-range": [10, 10],
		"circuitBreaker": { "maxFailures": 5, "resetOnSuccess": true, "mode": "skip" },
		"actions": [
			{ "action": "scroll", "amount": "page" },
			{
				"action": "click",
				"selector": "a[href='/fixpanel/financial/product/']",
				"textFallback": "Product",
				"expectsNavigation": true,
				"navigationTimeout": 8000
			},
			{ "action": "wait", "tier": "read" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "hover", "selector": "#rebalance" },
			{ "action": "click", "selector": "#rebalance", "textFallback": "Rebalance" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "[role=tab]", "textFallback": "Investments" },
			{ "action": "wait", "tier": "micro" },
			{ "action": "type", "selector": "input[type=number]", "text": "15000" },
			{ "action": "wait", "tier": "micro" },
			{ "action": "click", "selector": "#increaseInvestment", "textFallback": "Increase" },
			{ "action": "click", "selector": "#increaseInvestment", "textFallback": "Increase" },
			{ "action": "click", "selector": "#decreaseInvestment", "textFallback": "Decrease" },
			{ "action": "click", "selector": "[role=tab]", "textFallback": "Savings" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#increaseSavings", "textFallback": "Increase" },
			{ "action": "click", "selector": "#adjustGoal", "textFallback": "Goal" },
			{ "action": "click", "selector": "[role=tab]", "textFallback": "Expenses" },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#reduceExpenses", "textFallback": "Reduce" },
			{ "action": "scroll", "amount": "half" },
			{ "action": "click", "selector": "#generateReport", "textFallback": "Report" },
			{ "action": "wait", "tier": "think" },
			{ "action": "scroll", "direction": "up", "amount": "page" },
			{
				"action": "click",
				"selector": "#getStarted",
				"textFallback": "Get Started",
				"expectsNavigation": true,
				"navigationTimeout": 8000
			},
			{ "action": "wait", "tier": "read" },
			{ "action": "fillOutForm", "selector": "[role=radiogroup]", "clicksPerGroup": 4 },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#next" },
			{ "action": "wait", "tier": "read" },
			{ "action": "fillOutForm", "selector": "[role=radiogroup]", "clicksPerGroup": 4 },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#next" },
			{ "action": "wait", "tier": "read" },
			{ "action": "fillOutForm", "selector": "[role=radiogroup]", "clicksPerGroup": 25 },
			{ "action": "wait", "tier": "read" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted" },
			{ "action": "click", "selector": "#getStarted", "expectsNavigation": true, "navigationTimeout": 12000 }
		]
	}
}
