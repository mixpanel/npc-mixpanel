{
	"power-listener": {
		"description": "Power Listener: full funnel from landing to annual subscription with heavy engagement",
		"temperature": 8,
		"chaos-range": [8, 12],
		"circuitBreaker": { "maxFailures": 5, "resetOnSuccess": true, "mode": "skip" },
		"actions": [
			{ "action": "click", "selector": "#landingCta" },
			{ "action": "click", "selector": "#btnSignup" },
			{ "action": "type", "selector": "#signupName", "text": "{{displayName}}" },
			{ "action": "type", "selector": "#signupEmail", "text": "{{email}}" },
			{ "action": "click", "selector": "#signupForm button[type=\"submit\"]" },
			{ "action": "click", "selector": ".genre-select-card:nth-child(1)" },
			{ "action": "click", "selector": ".genre-select-card:nth-child(3)" },
			{ "action": "click", "selector": ".genre-select-card:nth-child(5)" },
			{ "action": "click", "selector": "#onboarding1Continue" },
			{ "action": "click", "selector": ".artist-item:nth-child(1)" },
			{ "action": "click", "selector": ".artist-item:nth-child(3)" },
			{ "action": "click", "selector": ".artist-item:nth-child(5)" },
			{ "action": "click", "selector": ".artist-item:nth-child(7)" },
			{ "action": "click", "selector": "#onboarding2Continue" },
			{ "action": "click", "selector": "#startListeningBtn" },
			{ "action": "click", "selector": ".nav-link[data-nav=\"browse\"]" },
			{ "action": "click", "selector": ".track-card:nth-child(1)" },
			{ "action": "click", "selector": ".track-card:nth-child(2)" },
			{ "action": "click", "selector": ".track-save-btn" },
			{ "action": "click", "selector": ".genre-pill:nth-child(2)" },
			{ "action": "click", "selector": ".track-card:nth-child(1)" },
			{ "action": "click", "selector": ".track-card:nth-child(2)" },
			{ "action": "click", "selector": "#playerSaveBtn" },
			{ "action": "click", "selector": "#genreBackBtn" },
			{ "action": "click", "selector": ".genre-pill:nth-child(5)" },
			{ "action": "click", "selector": ".track-card:nth-child(1)" },
			{ "action": "click", "selector": ".track-card:nth-child(2)" },
			{ "action": "click", "selector": ".track-card:nth-child(3)" },
			{ "action": "click", "selector": "#genreBackBtn" },
			{ "action": "click", "selector": ".nav-link[data-nav=\"genres\"]" },
			{ "action": "click", "selector": ".genre-card-large:nth-child(1)" },
			{ "action": "click", "selector": ".track-card:nth-child(1)" },
			{ "action": "click", "selector": "#btnSubscribeAnnual" }
		]
	}
}
